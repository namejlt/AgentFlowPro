# =============================================================================
# AgentFlow Pro 环境变量配置
# 复制此文件为 .env 并修改对应值：cp .env.example .env
# =============================================================================

# ---------- 应用 ----------
APP_NAME=AgentFlow Pro
GIN_MODE=release

# ---------- PostgreSQL ----------
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=agentflow_secret_2024
POSTGRES_DB=agentflow
POSTGRES_PORT=5432

# ---------- 后端服务 ----------
BACKEND_PORT=28131
HTTP_ADDR=:28131

# ---------- 前端服务 ----------
FRONTEND_PORT=28232

# ---------- 安全（生产环境必须修改） ----------
# JWT 密钥：至少 32 字符随机字符串
JWT_SECRET=change-me-to-a-random-64-char-string-in-production-xxxxx
# JWT 过期时间
JWT_EXPIRE=24h
# AES-256-GCM 加密密钥：恰好 32 字节（Base64 或原始字符串）
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ---------- 引擎 ----------
ENGINE_MAX_WORKERS=64
ENGINE_TASK_TIMEOUT=30m
